# このファイルを .env にコピーしてから値を埋める
# cp .env.example .env

# OptimismのRPCエンドポイント(まずは無料の公開RPCでOK)
RPC_URL=https://mainnet.optimism.io

# ICHIGOトークンのコントラクトアドレス
TOKEN_ADDR=0x836700463Dce76D9Cc3CDf6F6EDF946312c01869

# ガチャの送金先(自分のウォレットアドレスに変更すること)
GAME_WALLET=0x70775B1d24176De0fda2776303B8a603C671cFFb

# ガチャ1回あたりの必要金額(ICHIGO単位、小数点以下OK)
# gacha.html内のCOST定数(現在100)と必ず同じ値にすること
COST=100

# ESP32が /poll-unlock に問い合わせる際の合言葉(半角英数字。
# firmware/gachapon/gachapon.inoのSHARED_SECRETと同じ文字列にすること)
ESP32_SECRET=ここに好きな合言葉を入力(半角英数字)

# このブリッジサーバー自体が待ち受けるポート
PORT=3001

# --- AI店番エージェント(値切り交渉)機能。完全にオプトイン ---
# ANTHROPIC_API_KEYとNEGOTIATE_FLOOR_COSTの両方が設定されている場合のみ、
# /negotiate/ ・ /spectator/ ページと /negotiate-* エンドポイントが有効になる。
# どちらか片方でも未設定なら、この機能は無効のまま(既存の決済フローには影響しない)。

# Anthropic APIキー(https://console.anthropic.com/ で発行)
# ANTHROPIC_API_KEY=

# 交渉に使うモデル(未設定ならデフォルトの安価なモデルを使う)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Anthropicが障害・タイムアウト等で応答できなかった場合だけのフォールバック先(任意)。
# 未設定ならフォールバックせず、従来通り詫び文言を返してターンは消費しない。
# GEMINI_API_KEY=

# フォールバックに使うGeminiモデル(未設定ならデフォルトの安価なモデルを使う)
# GEMINI_MODEL=gemini-2.0-flash

# 通常の値切りで下げられる最低価格(ICHIGO単位)。COST以下にすること
# NEGOTIATE_FLOOR_COST=60

# 会話の質(機転・説得力・楽しさをAIが評価、0〜100)が満点の場合にだけ到達できる、
# 最も低い確定価格(ICHIGO単位)。NEGOTIATE_FLOOR_COST以下にすること。
# 価格が下がるのは運ではなく会話内容の良さによるものなので、抽選要素は無い。
# NEGOTIATE_ABSOLUTE_FLOOR=0

# 値切り交渉の最大ターン数(この回数に達したら自動的に価格が確定する)
# NEGOTIATE_MAX_TURNS=4

# 価格確定後、支払いが完了するまでクオートが有効な時間(ミリ秒)
# NEGOTIATE_QUOTE_TTL_MS=600000
