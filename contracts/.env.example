# デプロイ用ウォレットの秘密鍵(新規に生成した専用のもの、絶対にコミットしないこと)。
# このウォレットがデプロイ後のtrustedMinter(バウチャー署名者)にもなる。
DEPLOYER_PRIVATE_KEY=

# RPC(未設定ならHardhatの既定の公開RPCを使う)
OPTIMISM_RPC_URL=https://mainnet.optimism.io
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io

# 任意: OptimisticEtherscanでのソースコード検証用
OPTIMISTIC_ETHERSCAN_API_KEY=
