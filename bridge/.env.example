# このファイルを .env にコピーしてから値を埋める
# cp .env.example .env

# OptimismのRPCエンドポイント(まずは無料の公開RPCでOK)
RPC_URL=https://mainnet.optimism.io

# ICHIGOトークンのコントラクトアドレス
TOKEN_ADDR=0x836700463Dce76D9Cc3CDf6F6EDF946312c01869

# ガチャの送金先(自分のウォレットアドレスに変更すること)
GAME_WALLET=0x70775B1d24176De0fda2776303B8a603C671cFFb

# ガチャ1回あたりの必要金額(ICHIGO単位、小数点以下OK)
# gacha.html内のCOST定数(現在100)と必ず同じ値にすること
COST=100

# ESP32のローカルIPアドレス(gachapon.ino書き込み後、シリアルモニタに表示される)
ESP32_IP=192.168.1.50

# ESP32のスケッチ内 SHARED_SECRET と同じ文字列にすること
ESP32_SECRET=ここに好きな合言葉を入力

# このブリッジサーバー自体が待ち受けるポート
PORT=3001
