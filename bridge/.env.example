# このファイルを .env にコピーしてから値を埋める
# cp .env.example .env

# OptimismのRPCエンドポイント(まずは無料の公開RPCでOK)
RPC_URL=https://mainnet.optimism.io

# ICHIGOトークンのコントラクトアドレス
TOKEN_ADDR=0x836700463Dce76D9Cc3CDf6F6EDF946312c01869

# ガチャの送金先(自分のウォレットアドレスに変更すること)
GAME_WALLET=0x70775B1d24176De0fda2776303B8a603C671cFFb

# ガチャ1回あたりの必要金額(ICHIGO単位、小数点以下OK)。定価。
COST=2000

# ESP32が /poll-unlock に問い合わせる際の合言葉(半角英数字。
# firmware/gachapon/gachapon.inoのSHARED_SECRETと同じ文字列にすること)
ESP32_SECRET=ここに好きな合言葉を入力(半角英数字)

# /negotiate-admin-*系(スタッフが価格を直接確定・上書きしたり購入履歴を見るための
# エンドポイント)専用の合言葉。未設定ならESP32_SECRETにフォールバックするが、
# 本番イベントでは物理操作用のESP32_SECRETとは別の値を設定することを推奨する
# (こちらは実質的に金銭価値のある操作を守るため)。
# NEGOTIATE_ADMIN_SECRET=

# このブリッジサーバー自体が待ち受けるポート
PORT=3001

# --- AI店番エージェント(値切り交渉)機能 ---
# /negotiate/ ページ自体は常に使える(下記3つのAPIキーがすべて無い場合は、AIの代わりに
# スタッフが対面で交渉して価格を直接入力する「manualモード」で動作する)。
# OPENAI_API_KEY/ANTHROPIC_API_KEY/(CLOUDFLARE_ACCOUNT_ID+CLOUDFLARE_API_TOKEN)のいずれか1つと
# NEGOTIATE_FLOOR_COSTが設定されていれば、AIによる自動値切りが有効になる。
# 実際の交渉は「OpenAI→Anthropic(Claude Haiku)→Cloudflare Workers AI」の順で
# 3段階フォールバックする(前段が未設定、またはAPI障害・タイムアウト等で応答できなかった
# 場合だけ次段に進む。全段が未設定/失敗ならmanualモード相当の詫び文言になる)。

# 第一優先。OpenAI APIキー(https://platform.openai.com/ で発行)
# OPENAI_API_KEY=

# 交渉に使うモデル(未設定ならデフォルトの安価なモデルを使う)
# OPENAI_MODEL=gpt-4o-mini

# 第二優先(フォールバック)。Anthropic APIキー(https://console.anthropic.com/ で発行)
# ANTHROPIC_API_KEY=

# 交渉に使うモデル(未設定ならデフォルトの安価なモデルを使う)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# 普通に愛想よく会話しているだけ(特別な機転・授業知識が無くても)下げられる
# 最低価格(ICHIGO単位)。COST以下にすること。
# NEGOTIATE_FLOOR_COST=1500

# 「本当に機転が利いた発言」または「授業(web3/AI概論)の内容にゆるくでも触れた発言」が
# あった場合にだけ一気に到達できる、最も低い確定価格(ICHIGO単位)。NEGOTIATE_FLOOR_COST以下にすること。
# 価格が下がるのは運ではなく会話内容の良さによるものなので、抽選要素は無い。
# NEGOTIATE_ABSOLUTE_FLOOR=1000

# 値切り交渉の最大ターン数(この回数に達したら自動的に価格が確定する)。
# 当日の時間制約に合わせて短くする場合はここを減らす(例: 2)。ターン数が少ないほど
# AIは初手からでもまとまった値下げを出すよう指示されている(negotiation.js参照)。
# NEGOTIATE_MAX_TURNS=2

# 価格確定後、支払いが完了するまでクオートが有効な時間(ミリ秒)
# NEGOTIATE_QUOTE_TTL_MS=600000

# --- 第三優先(最終フォールバック): Cloudflare Workers AI ---
# CLOUDFLARE_ACCOUNT_IDとCLOUDFLARE_API_TOKENの両方を設定すると、OpenAI・Anthropicのどちらも
# 未設定または応答できなかった場合の最後のフォールバック先として使われる
# (無料枠1日1万ニューロン)。

# CloudflareのアカウントID(https://dash.cloudflare.com/ の右サイドバーで確認できる)
# CLOUDFLARE_ACCOUNT_ID=

# Workers AIの実行権限を持つAPIトークン(https://dash.cloudflare.com/profile/api-tokens で発行)
# CLOUDFLARE_API_TOKEN=

# 使うモデル(未設定ならデフォルトのLlama 3.1 8B。function calling対応モデルのみ使えること)
# CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

# --- オンライン参加(ウォレット接続→AI交渉→ICHIGO送金→NFT受け取り)機能 ---
# AI店番(上記ANTHROPIC_API_KEY等)が有効、かつ下のNFT配布方法(モックまたは実コントラクト)の
# どちらかが設定されている場合のみ、オンライン参加そのものが有効になる。

# テスト用: '1'にすると、NFTコントラクトが未デプロイでもオンライン参加フロー全体
# (ウォレット接続〜AI交渉〜実際のICHIGO送金〜景品抽選)を試せる。ただしNFTは実際には
# mintされない(claim()呼び出し自体をクライアント側でスキップする)。
# 本番では必ず未設定にすること。
# GACHA_NFT_MOCK_MODE=1

# デプロイ済みのIchigoGachaNFT(ERC-1155)コントラクトアドレス(Optimismメインネット)。
# contracts/scripts/deploy.js の実行結果を貼る。
# NFT_CONTRACT_ADDR=

# バウチャー(claim用の署名)を発行する専用ウォレットの秘密鍵。このウォレットは
# コントラクトのtrustedMinterと一致している必要があり、オフチェーン署名しか行わない
# (mintのガス代は参加者が払うため、このウォレット自体はETHを保有する必要がない)。
# 絶対にコミットしないこと。
# ONLINE_MINTER_PRIVATE_KEY=

# オンライン交渉の同時受付人数
# ONLINE_MAX_CONCURRENT=2

# 決済確認からmint(claim)可能な期限まりの猶予(ミリ秒)。決済は既に確認済みなので、
# 交渉のクオートより長め(既定24時間)にしている。
# ONLINE_VOUCHER_TTL_MS=86400000
